generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(DOCTOR)
  createdAt    DateTime     @default(now())
  invitations Invitation[]
}

model Invitation {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String   @unique
  role        Role     @default(DOCTOR)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
}

model Owner {
  id        String    @id @default(cuid())
  name      String
  phone     String
  email     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  patients  Patient[]

  @@index([name])
  @@index([email])
}

model Patient {
  id            String   @id @default(cuid())
  name          String
  species       String
  breed         String
  birthDate     DateTime?
  weightKg      Float?
  photoUrl      String?
  photoPublicId String?
  ownerId       String
  owner         Owner    @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@index([ownerId])
}
